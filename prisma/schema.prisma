// Akron — Prisma Schema v6
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  TRIAL
  PRO
}

enum Canal {
  META
  GOOGLE
  TIKTOK
  LINKEDIN
}

enum AlertStatus {
  NOVO
  APLICADO
  IGNORADO
}

enum ActionType {
  PAUSE
  BID
  BUDGET
}

enum ExecutionStatus {
  PENDING
  SUCCESS
  FAILED
}

// ─── Auth.js v5 (standard models) ────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  // Stripe
  stripeCustomerId       String?
  stripePriceId          String?
  stripeSubscriptionId   String?
  stripeCurrentPeriodEnd DateTime?

  // Trial / Plan
  trialEndsAt DateTime?
  plan        Plan      @default(FREE)

  accounts Account[]
  sessions Session[]

  alerts        Alert[]
  actions       Action[]
  executionLogs ExecutionLog[]
  clusters      Cluster[]
  clients       Client[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Produto: Akron ───────────────────────────────────────────────────────────

model Alert {
  id              String      @id @default(cuid())
  workspaceId     String
  canal           Canal
  campanhaId      String
  tipo            String
  diagnostico     String      @db.Text
  impactoProjetado String?
  prioridade      Int         @default(0)
  status          AlertStatus @default(NOVO)

  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  actions Action[]

  criadoEm DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Action {
  id         String     @id @default(cuid())
  alertId    String
  tipo       ActionType
  payload    Json
  canal      Canal
  aplicadoPor String
  aplicadoEm  DateTime  @default(now())
  metricasAntes Json?

  alert         Alert          @relation(fields: [alertId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [aplicadoPor], references: [id])
  executionLogs ExecutionLog[]
}

model ExecutionLog {
  id             String          @id @default(cuid())
  actionId       String
  userId         String
  canal          Canal
  campanha       String
  acao           String
  metricasAntes  Json?
  metricasDepois Json?
  delta          Float?
  status         ExecutionStatus @default(PENDING)

  action Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  criadoEm DateTime @default(now())
}

model Cluster {
  id          String   @id @default(cuid())
  workspaceId String
  nome        String
  campanhas   String[]
  criadoPor   String
  criadoEm    DateTime @default(now())

  user User @relation(fields: [criadoPor], references: [id])
}

model MetricsStore {
  id          String   @id @default(cuid())
  canal       Canal
  campanhaId  String
  data        DateTime
  impressoes  Int      @default(0)
  cliques     Int      @default(0)
  gasto       Int      @default(0)
  conversoes  Int      @default(0)
  roas        Float    @default(0)
  cpa         Float    @default(0)
  frequencia  Float    @default(0)
  ctr         Float    @default(0)

  @@unique([canal, campanhaId, data])
}

model Client {
  id               String   @id @default(cuid())
  workspaceId      String
  nome             String
  metricasRapidas  Json?
  canaisConectados String[]

  userId String
  user   User   @relation(fields: [userId], references: [id])

  criadoEm DateTime @default(now())
}
